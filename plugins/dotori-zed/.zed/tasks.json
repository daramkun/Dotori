[
  {
    "label": "dotori: build",
    "command": "dotori",
    "args": ["build", "--all"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "dotori: build (release)",
    "command": "dotori",
    "args": ["build", "--all", "--release"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "dotori: run",
    "command": "dotori",
    "args": ["run"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "dotori: run (release)",
    "command": "dotori",
    "args": ["run", "--release"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "dotori: clean",
    "command": "dotori",
    "args": ["clean", "--all"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "dotori: test",
    "command": "dotori",
    "args": ["test"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "dotori: export compile-commands",
    "command": "dotori",
    "args": ["export", "compile-commands", "--all"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "never"
  }
]
