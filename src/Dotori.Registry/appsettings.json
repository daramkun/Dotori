{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=registry.db"
  },
  "Registry": {
    "Mode": "standalone",
    "StorageRoot": "packages",
    "ProxyUpstream": null,
    "ProxyCacheTtlHours": 24
  },
  "OAuth": {
    "Jwt": {
      "Secret": "CHANGE_THIS_SECRET_IN_PRODUCTION_AT_LEAST_32_CHARS",
      "ExpiryDays": 365,
      "Issuer": "dotori-registry",
      "Audience": "dotori-client"
    },
    "DeviceCodeExpiryMinutes": 15,
    "Providers": {
      "github": {
        "Enabled": false,
        "ClientId": "",
        "ClientSecret": ""
      }
    }
  }
}
