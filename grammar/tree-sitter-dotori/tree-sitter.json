{
  "grammars": [
    {
      "name": "dotori",
      "camelcase": "Dotori",
      "scope": "source.dotori",
      "path": ".",
      "file-types": [
        "dotori"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Dotori C++ build system DSL (.dotori files)",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-dotori"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
